# ============================================================
# TransitOps — Environment Variables (Development)
# ============================================================

# Server
NODE_ENV=development
PORT=3000

# Database (MySQL via Prisma)
DATABASE_URL="mysql://root:password@localhost:3306/transit_ops"

# JWT
JWT_SECRET=transitops_jwt_secret_key_change_in_production_2026
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Bcrypt
BCRYPT_SALT_ROUNDS=12

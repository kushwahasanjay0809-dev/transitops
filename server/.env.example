# ============================================================
# TransitOps Server — Environment Variables
# ============================================================

# Server
NODE_ENV=production
PORT=5000

# Database (MySQL)
DATABASE_URL=mysql://root:YOUR_PASSWORD@localhost:3306/transit_ops

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:3000
